# ========================================
# PropToken - Environment Variables
# ========================================
# 
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to GitHub!
#

# Network RPC URLs
# Get free RPC URLs from: https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private key for deployment
# ⚠️ SECURITY WARNING: NEVER commit your actual private key!
# Export from MetaMask: Account Details → Export Private Key
# Remove the '0x' prefix if present
PRIVATE_KEY=your_wallet_private_key_here_without_0x_prefix

# Etherscan API key for contract verification
# Get free API key from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Gas reporting (set to true to enable gas usage reports in tests)
REPORT_GAS=false
